# Copia este archivo a .env y ajusta los valores.  NO subas .env al repositorio.

# Base de datos (async driver)
DATABASE_URL=postgresql+asyncpg://pguser:pgpass@db:5432/chapi

# Redis (cola arq)
REDIS_URL=redis://redis:6379/0

# Control de acceso mínimo (T-102). Vacío = modo abierto (MVP/dev, sin auth).
# Si se define, la API exige la clave (header X-API-Key o Authorization: Bearer)
# en los endpoints de negocio. Auth por usuario/RBAC: fase 2.
API_KEY=

# Credenciales usadas por el contenedor de Postgres
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpass
POSTGRES_DB=chapi

# Scraper: true = mock (MVP), false = Playwright real (fase 2)
USE_MOCK_SCRAPER=true

# Rango de años por defecto para la búsqueda
DEFAULT_YEAR_FROM=2018
DEFAULT_YEAR_TO=2024

# Carpeta de salida (JSON por persona + informes HTML)
RESULTS_DIR=results

# Politeness/rate limiting hacia la fuente (T-104). Efectivo con el scraper real.
SCRAPER_MIN_DELAY_SECONDS=1.0
SCRAPER_JITTER_SECONDS=0.5
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_BASE_SECONDS=1.0

# Scraper real (fase 2). Chromium headless dentro del contenedor.
SCRAPER_HEADLESS=true
# El scraper real es lento; timeout del job de arq (segundos).
ARQ_JOB_TIMEOUT_SECONDS=1800

# NLP (T-210). true = síntesis mock (rule-based, MVP); false = llama-cpp (fase 2).
USE_MOCK_NLP=true
ENABLE_SUMMARY=true
LLAMA_MODEL_PATH=./models/llama-q4.gguf
LLAMA_N_CTX=4096

# Embeddings / búsqueda semántica (T-211/T-212). true = mock hashing (MVP);
# false = sentence-transformers (fase 2, requirements-ml.txt + overlay pgvector).
USE_MOCK_EMBEDDINGS=true
ENABLE_SEMANTIC_SEARCH=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=64
